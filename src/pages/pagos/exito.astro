---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PaymentReturn from "../../components/PaymentReturn.astro";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoColor = `${basePath}/logo_color.png`;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoColor} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pago exitoso | Jessica Quiroz</title>
    <meta name="description" content="Retorno de pago exitoso para reservas de Jessica Quiroz." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main class="pt-20">
      <PaymentReturn
        kind="success"
        tone="success"
        icon="check_circle"
        eyebrow="Pago exitoso"
        title="Gracias por tu reserva"
        description="Recibimos el retorno del pago. Si Mercado Pago ya confirmo la operacion, tu hora quedara agendada automaticamente."
      />
    </main>
    <Footer />
  </body>
</html>
