---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PaymentReturn from "../../components/PaymentReturn.astro";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoColor = `${basePath}/logo_color.png`;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoColor} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Pago pendiente | Jessica Quiróz</title>
    <meta name="description" content="Retorno de pago pendiente para reservas de Jessica Quiróz." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main class="pt-20">
      <PaymentReturn
        kind="pending"
        tone="pending"
        icon="pending_actions"
        eyebrow="Pago pendiente"
        title="Tu pago esta en revision"
        description="Mercado Pago aun no confirma la operacion. Apenas el backend reciba la confirmacion, la reserva podra quedar agendada."
      />
    </main>
    <Footer />
  </body>
</html>
