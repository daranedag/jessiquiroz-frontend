---
import "../../styles/global.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
const logoColor = `${basePath}/logo_color.png`;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || "";
const apiV1Path = import.meta.env.PUBLIC_API_V1_PATH || "/api/v1";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={logoColor} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Solicitar eliminación de información | Jessica Quiróz</title>
    <meta
      name="description"
      content="Solicita la eliminación de tu información personal asociada a Jessica Quiróz."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Montserrat:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  </head>
  <body>
    <Header />
    <main class="min-h-[calc(100vh-5rem)] bg-background py-24 pt-36">
      <section
        class="mx-auto max-w-4xl px-6"
        data-deletion-request
        data-api-base-url={apiBaseUrl}
        data-api-v1-path={apiV1Path}
      >
        <div class="text-center">
          <span class="inline-flex h-20 w-20 items-center justify-center rounded-full bg-primary text-white">
            <span class="material-icons text-4xl">delete_outline</span>
          </span>
          <p class="mt-8 text-xs font-semibold uppercase tracking-[0.3em] text-secondary">Privacidad</p>
          <h1 class="mt-3 font-display text-4xl text-text-main sm:text-5xl">Solicita la eliminación de tu información</h1>
          <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-slate-600">
            Ingresa el correo electrónico que usaste al reservar. Te enviaremos una verificación antes de procesar la solicitud.
          </p>
        </div>

        <form class="mx-auto mt-10 max-w-2xl space-y-6 rounded-3xl border border-primary/10 bg-white p-6 shadow-sm sm:p-8" data-deletion-form>
          <label class="block space-y-2 text-sm font-medium text-text-main">
            <span>Correo electrónico de la reserva</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
            />
          </label>

          <label class="block space-y-2 text-sm font-medium text-text-main">
            <span>Confirma tu correo electrónico</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="emailConfirmation"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
            />
          </label>

          <p class="rounded-2xl bg-background-alt/40 px-4 py-3 text-sm leading-6 text-slate-700">
            La solicitud no elimina información de forma automática. Verificaremos que tienes acceso a este correo y revisaremos si existen datos que debamos conservar por obligaciones legales.
          </p>

          <div class="rounded-2xl border border-primary/10 bg-white px-4 py-3 text-sm text-slate-600" role="status" aria-live="polite" data-deletion-status>
            Completa y confirma tu correo para enviar la solicitud.
          </div>

          <button
            class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-cta px-8 py-4 text-xs font-bold uppercase tracking-[0.2em] text-text-main shadow-lg ring-2 ring-cta/70 transition hover:-translate-y-0.5 hover:shadow-2xl disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:translate-y-0"
            type="submit"
            data-submit-button
          >
            <span class="material-icons text-base">mark_email_read</span>
            Enviar solicitud
          </button>
        </form>
      </section>
    </main>
    <Footer />

    <script>
      const deletionRequest = document.querySelector<HTMLElement>("[data-deletion-request]");

      if (deletionRequest) {
        const form = deletionRequest.querySelector<HTMLFormElement>("[data-deletion-form]");
        const statusBox = deletionRequest.querySelector<HTMLElement>("[data-deletion-status]");
        const submitButton = deletionRequest.querySelector<HTMLButtonElement>("[data-submit-button]");
        const apiBaseUrl = deletionRequest.dataset.apiBaseUrl?.replace(/\/$/, "") || "";
        const apiV1Path = deletionRequest.dataset.apiV1Path?.replace(/^\/?/, "/").replace(/\/$/, "") || "/api/v1";
        const endpoint = `${apiBaseUrl}${apiV1Path}/privacy/deletion-requests`;

        const setStatus = (message: string, tone: "neutral" | "error" | "success" = "neutral") => {
          if (!statusBox) return;
          const toneClasses = {
            neutral: "border-primary/10 bg-white text-slate-600",
            error: "border-red-200 bg-red-50 text-red-700",
            success: "border-primary/20 bg-primary/10 text-primary",
          };
          statusBox.className = `rounded-2xl border px-4 py-3 text-sm ${toneClasses[tone]}`;
          statusBox.textContent = message;
        };

        const setBusy = (busy: boolean) => {
          if (!submitButton) return;
          submitButton.disabled = busy;
          submitButton.querySelector("span")?.classList.toggle("animate-pulse", busy);
        };

        const getApiError = async (response: Response) => {
          try {
            const payload = await response.json();
            return payload?.error?.message ?? "No fue posible enviar la solicitud. Inténtalo nuevamente.";
          } catch {
            return "No fue posible enviar la solicitud. Inténtalo nuevamente.";
          }
        };

        form?.addEventListener("submit", async (event) => {
          event.preventDefault();
          const formData = new FormData(form);
          const email = String(formData.get("email") ?? "").trim().toLowerCase();
          const emailConfirmation = String(formData.get("emailConfirmation") ?? "").trim().toLowerCase();

          if (email !== emailConfirmation) {
            setStatus("Los correos electrónicos no coinciden.", "error");
            return;
          }

          if (!apiBaseUrl) {
            setStatus("El formulario todavía no está disponible. Inténtalo más tarde.", "error");
            return;
          }

          setBusy(true);
          setStatus("Enviando solicitud...");

          try {
            const response = await fetch(endpoint, {
              method: "POST",
              headers: {
                Accept: "application/json",
                "Content-Type": "application/json",
              },
              body: JSON.stringify({ email }),
            });

            if (!response.ok) throw new Error(await getApiError(response));

            form.reset();
            setStatus("Si encontramos información asociada a este correo, recibirás un mensaje para verificar la solicitud.", "success");
          } catch (error) {
            setStatus(error instanceof Error ? error.message : "No fue posible enviar la solicitud. Inténtalo nuevamente.", "error");
          } finally {
            setBusy(false);
          }
        });
      }
    </script>
  </body>
</html>
