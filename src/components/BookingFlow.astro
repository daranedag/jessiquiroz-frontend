---
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? "";
const availabilityPath = import.meta.env.PUBLIC_BOOKING_AVAILABILITY_PATH ?? "/calendar/availability";
const uploadPath = import.meta.env.PUBLIC_BOOKING_UPLOAD_PATH ?? "/uploads";
const prebookPath = import.meta.env.PUBLIC_BOOKING_PREBOOK_PATH ?? "/appointments/prebook";
const confirmPaymentPath = import.meta.env.PUBLIC_BOOKING_CONFIRM_PAYMENT_PATH ?? "/appointments/confirm-payment";

const services = [
  { id: "rejuvenecimiento-facial", name: "Rejuvenecimiento facial" },
  { id: "armonizacion-corporal", name: "Armonización corporal" },
  { id: "sanacion-energetica", name: "Sanación energética" },
];
---

<section
  id="agendamiento"
  class="bg-white py-16"
  data-booking-flow
  data-api-base-url={apiBaseUrl}
  data-availability-path={availabilityPath}
  data-upload-path={uploadPath}
  data-prebook-path={prebookPath}
  data-confirm-payment-path={confirmPaymentPath}
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-secondary">Agenda</p>
        <h2 class="mt-2 font-display text-3xl text-text-main sm:text-4xl">Reserva tu sesión</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Selecciona una hora disponible, comparte tus datos y completa el pago para confirmar la reserva.
        </p>

        <div class="mt-8 grid gap-4 text-sm text-slate-700">
          <div class="flex gap-3">
            <span class="material-icons text-primary">event_available</span>
            <span>La hora queda bloqueada al iniciar el pago.</span>
          </div>
          <div class="flex gap-3">
            <span class="material-icons text-primary">image</span>
            <span>Puedes adjuntar imágenes de referencia antes de pagar.</span>
          </div>
          <div class="flex gap-3">
            <span class="material-icons text-primary">verified</span>
            <span>La confirmación final se valida con el backend después del pago.</span>
          </div>
        </div>
      </div>

      <form class="space-y-8 rounded-3xl border border-primary/10 bg-background/50 p-6 shadow-sm sm:p-8" data-booking-form>
        <div class="flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          <span class="rounded-full bg-primary px-4 py-2 text-white" data-step-indicator="1">Datos</span>
          <span class="rounded-full bg-white px-4 py-2 text-primary" data-step-indicator="2">Horario</span>
          <span class="rounded-full bg-white px-4 py-2 text-primary" data-step-indicator="3">Pago</span>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Nombre</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="name"
              autocomplete="name"
              required
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Email</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="email"
              type="email"
              autocomplete="email"
              required
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Teléfono</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="phone"
              type="tel"
              autocomplete="tel"
              required
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Servicio</span>
            <select
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="service"
              required
            >
              <option value="">Selecciona</option>
              {services.map((service) => <option value={service.id}>{service.name}</option>)}
            </select>
          </label>
        </div>

        <div class="grid gap-5 sm:grid-cols-[0.75fr_1.25fr]">
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Fecha</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="date"
              type="date"
              required
              data-date-input
            />
          </label>

          <div class="space-y-2">
            <span class="block text-sm font-medium text-text-main">Horas disponibles</span>
            <div class="grid min-h-14 grid-cols-2 gap-3 sm:grid-cols-3" data-slot-list>
              <p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">Elige servicio y fecha.</p>
            </div>
          </div>
        </div>

        <input type="hidden" name="slotId" data-slot-input />

        <label class="space-y-2 text-sm font-medium text-text-main">
          <span>Mensaje</span>
          <textarea
            class="min-h-28 w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
            name="notes"
            maxlength="700"
          ></textarea>
        </label>

        <label class="block space-y-3 text-sm font-medium text-text-main">
          <span>Imágenes</span>
          <input
            class="block w-full rounded-2xl border border-dashed border-primary/30 bg-white px-4 py-6 text-sm text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white"
            name="files"
            type="file"
            accept="image/*"
            multiple
            data-file-input
          />
          <span class="block text-xs font-normal text-slate-500" data-file-summary>Máximo 5 imágenes, 6 MB por archivo.</span>
        </label>

        <label class="flex items-start gap-3 text-sm text-slate-600">
          <input class="mt-1 h-4 w-4 rounded border-primary/30 text-primary" type="checkbox" name="acceptTerms" required />
          <span>Acepto compartir estos datos para gestionar mi reserva y pago.</span>
        </label>

        <div class="rounded-2xl border border-primary/10 bg-white px-4 py-3 text-sm text-slate-600" role="status" data-booking-status>
          Completa los datos para continuar.
        </div>

        <button
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-cta px-8 py-4 text-xs font-bold uppercase tracking-[0.2em] text-text-main shadow-lg ring-2 ring-cta/70 transition hover:-translate-y-0.5 hover:shadow-2xl disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:translate-y-0"
          type="submit"
          data-submit-button
        >
          <span class="material-icons text-base">payments</span>
          Ir al pago
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  type Slot = {
    id: string;
    label: string;
    start?: string;
    end?: string;
    available?: boolean;
  };

  type UploadedFile = {
    id?: string;
    url?: string;
    name?: string;
  };

  const flow = document.querySelector<HTMLElement>("[data-booking-flow]");

  if (flow) {
    const form = flow.querySelector<HTMLFormElement>("[data-booking-form]");
    const slotList = flow.querySelector<HTMLElement>("[data-slot-list]");
    const slotInput = flow.querySelector<HTMLInputElement>("[data-slot-input]");
    const dateInput = flow.querySelector<HTMLInputElement>("[data-date-input]");
    const fileInput = flow.querySelector<HTMLInputElement>("[data-file-input]");
    const fileSummary = flow.querySelector<HTMLElement>("[data-file-summary]");
    const statusBox = flow.querySelector<HTMLElement>("[data-booking-status]");
    const submitButton = flow.querySelector<HTMLButtonElement>("[data-submit-button]");
    const indicators = Array.from(flow.querySelectorAll<HTMLElement>("[data-step-indicator]"));

    const apiBaseUrl = flow.dataset.apiBaseUrl?.replace(/\/$/, "") ?? "";
    const availabilityPath = flow.dataset.availabilityPath ?? "/calendar/availability";
    const uploadPath = flow.dataset.uploadPath ?? "/uploads";
    const prebookPath = flow.dataset.prebookPath ?? "/appointments/prebook";
    const confirmPaymentPath = flow.dataset.confirmPaymentPath ?? "/appointments/confirm-payment";
    const maxFiles = 5;
    const maxFileSize = 6 * 1024 * 1024;

    const endpoint = (path: string) => `${apiBaseUrl}${path.startsWith("/") ? path : `/${path}`}`;

    const setStatus = (message: string, tone: "neutral" | "error" | "success" = "neutral") => {
      if (!statusBox) return;
      const toneClasses = {
        neutral: "border-primary/10 bg-white text-slate-600",
        error: "border-red-200 bg-red-50 text-red-700",
        success: "border-green-200 bg-green-50 text-green-700",
      };
      statusBox.className = `rounded-2xl border px-4 py-3 text-sm ${toneClasses[tone]}`;
      statusBox.textContent = message;
    };

    const setStep = (step: string) => {
      indicators.forEach((indicator) => {
        const isActive = indicator.dataset.stepIndicator === step;
        indicator.classList.toggle("bg-primary", isActive);
        indicator.classList.toggle("text-white", isActive);
        indicator.classList.toggle("bg-white", !isActive);
        indicator.classList.toggle("text-primary", !isActive);
      });
    };

    const setBusy = (busy: boolean) => {
      if (!submitButton) return;
      submitButton.disabled = busy;
      submitButton.querySelector("span")?.classList.toggle("animate-pulse", busy);
    };

    const normalizeSlot = (slot: unknown): Slot | null => {
      if (typeof slot === "string") {
        return { id: slot, label: slot, available: true };
      }
      if (!slot || typeof slot !== "object") return null;
      const value = slot as Record<string, unknown>;
      const id = String(value.id ?? value.slotId ?? value.start ?? "");
      if (!id) return null;
      const start = typeof value.start === "string" ? value.start : undefined;
      const end = typeof value.end === "string" ? value.end : undefined;
      const label = String(value.label ?? value.time ?? formatSlotLabel(start, end) ?? id);
      return {
        id,
        label,
        start,
        end,
        available: value.available !== false,
      };
    };

    const formatSlotLabel = (start?: string, end?: string) => {
      if (!start) return undefined;
      const startLabel = start.includes("T") ? new Date(start).toLocaleTimeString("es-CL", { hour: "2-digit", minute: "2-digit" }) : start;
      if (!end) return startLabel;
      const endLabel = end.includes("T") ? new Date(end).toLocaleTimeString("es-CL", { hour: "2-digit", minute: "2-digit" }) : end;
      return `${startLabel} - ${endLabel}`;
    };

    const renderSlots = (slots: Slot[]) => {
      if (!slotList || !slotInput) return;
      slotInput.value = "";
      slotList.innerHTML = "";

      const availableSlots = slots.filter((slot) => slot.available !== false);
      if (!availableSlots.length) {
        slotList.innerHTML = '<p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">No hay horas disponibles para esa fecha.</p>';
        return;
      }

      availableSlots.forEach((slot) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm font-semibold text-primary transition hover:border-primary hover:bg-primary hover:text-white";
        button.textContent = slot.label;
        button.addEventListener("click", () => {
          slotInput.value = slot.id;
          slotList.querySelectorAll("button").forEach((item) => {
            item.classList.remove("border-primary", "bg-primary", "text-white");
            item.classList.add("border-primary/20", "bg-white", "text-primary");
          });
          button.classList.add("border-primary", "bg-primary", "text-white");
          button.classList.remove("border-primary/20", "bg-white", "text-primary");
          setStep("3");
          setStatus("Hora seleccionada. Puedes continuar al pago.");
        });
        slotList.append(button);
      });
    };

    const loadAvailability = async () => {
      if (!form || !slotList) return;
      const formData = new FormData(form);
      const service = String(formData.get("service") ?? "");
      const date = String(formData.get("date") ?? "");

      if (!service || !date) {
        renderSlots([]);
        setStatus("Elige servicio y fecha para consultar disponibilidad.");
        return;
      }

      if (!apiBaseUrl) {
        setStatus("Falta configurar PUBLIC_API_BASE_URL.", "error");
        return;
      }

      setStep("2");
      slotList.innerHTML = '<p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">Consultando disponibilidad...</p>';

      try {
        const url = new URL(endpoint(availabilityPath));
        url.searchParams.set("service", service);
        url.searchParams.set("date", date);
        const response = await fetch(url, { headers: { Accept: "application/json" } });
        if (!response.ok) throw new Error("No se pudo consultar disponibilidad.");
        const payload = await response.json();
        const rawSlots = Array.isArray(payload) ? payload : payload.slots ?? payload.data ?? [];
        renderSlots(rawSlots.map(normalizeSlot).filter(Boolean) as Slot[]);
      } catch (error) {
        renderSlots([]);
        setStatus(error instanceof Error ? error.message : "No se pudo consultar disponibilidad.", "error");
      }
    };

    const validateFiles = () => {
      const files = Array.from(fileInput?.files ?? []);
      if (files.length > maxFiles) {
        throw new Error(`Puedes subir hasta ${maxFiles} imágenes.`);
      }
      const invalidFile = files.find((file) => !file.type.startsWith("image/") || file.size > maxFileSize);
      if (invalidFile) {
        throw new Error(`Revisa ${invalidFile.name}: solo imágenes de hasta 6 MB.`);
      }
      if (fileSummary) {
        fileSummary.textContent = files.length ? `${files.length} imagen(es) seleccionada(s).` : "Máximo 5 imágenes, 6 MB por archivo.";
      }
      return files;
    };

    const uploadFiles = async (files: File[]) => {
      if (!files.length) return [];
      const body = new FormData();
      files.forEach((file) => body.append("files", file));

      const response = await fetch(endpoint(uploadPath), {
        method: "POST",
        body,
      });
      if (!response.ok) throw new Error("No se pudieron subir las imágenes.");
      const payload = await response.json();
      const uploads = Array.isArray(payload) ? payload : payload.files ?? payload.data ?? [];
      return uploads as UploadedFile[];
    };

    const createPrebooking = async (payload: Record<string, unknown>) => {
      const response = await fetch(endpoint(prebookPath), {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      if (!response.ok) throw new Error("No se pudo iniciar la reserva.");
      return response.json();
    };

    const confirmPayment = async () => {
      if (!apiBaseUrl) return;
      const params = new URLSearchParams(window.location.search);
      const status = params.get("payment_status") ?? params.get("status") ?? params.get("collection_status");
      const approved = status === "success" || status === "approved";
      if (!approved) return;

      const prebookingId =
        params.get("prebooking_id") ?? params.get("external_reference") ?? window.sessionStorage.getItem("jq_prebooking_id");
      if (!prebookingId) {
        setStatus("Pago aprobado, pero falta el identificador de pre-reserva.", "error");
        return;
      }

      setStep("3");
      setStatus("Validando pago y confirmando reserva...");

      try {
        const response = await fetch(endpoint(confirmPaymentPath), {
          method: "POST",
          headers: {
            Accept: "application/json",
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            prebookingId,
            paymentId: params.get("payment_id") ?? params.get("collection_id"),
            preferenceId: params.get("preference_id"),
            merchantOrderId: params.get("merchant_order_id"),
            status,
          }),
        });
        if (!response.ok) throw new Error("El pago fue recibido, pero la confirmación quedó pendiente.");
        window.sessionStorage.removeItem("jq_prebooking_id");
        setStatus("Pago confirmado. Tu hora quedó agendada.", "success");
      } catch (error) {
        setStatus(error instanceof Error ? error.message : "No se pudo confirmar la reserva.", "error");
      }
    };

    form?.addEventListener("change", (event) => {
      const target = event.target as HTMLInputElement | HTMLSelectElement;
      if (target.name === "service" || target.name === "date") {
        loadAvailability();
      }
      if (target === fileInput) {
        try {
          validateFiles();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Archivo no válido.", "error");
          if (fileInput) fileInput.value = "";
        }
      }
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      try {
        if (!apiBaseUrl) throw new Error("Falta configurar PUBLIC_API_BASE_URL.");
        if (!form.reportValidity()) return;

        const formData = new FormData(form);
        const slotId = String(formData.get("slotId") ?? "");
        if (!slotId) throw new Error("Selecciona una hora disponible.");

        setBusy(true);
        setStatus("Preparando la pre-reserva...");

        const files = validateFiles();
        const uploadedFiles = await uploadFiles(files);

        const returnUrl = new URL(window.location.href);
        returnUrl.search = "";

        const prebooking = await createPrebooking({
          customer: {
            name: formData.get("name"),
            email: formData.get("email"),
            phone: formData.get("phone"),
          },
          service: formData.get("service"),
          date: formData.get("date"),
          slotId,
          notes: formData.get("notes"),
          files: uploadedFiles,
          payment: {
            successUrl: `${returnUrl.toString()}?payment_status=success`,
            failureUrl: `${returnUrl.toString()}?payment_status=failure`,
            pendingUrl: `${returnUrl.toString()}?payment_status=pending`,
          },
        });

        const prebookingId = prebooking.prebookingId ?? prebooking.id ?? prebooking.externalReference;
        const paymentUrl = prebooking.paymentUrl ?? prebooking.initPoint ?? prebooking.checkoutUrl;

        if (!paymentUrl) throw new Error("El backend no devolvió una URL de pago.");
        if (prebookingId) {
          window.sessionStorage.setItem("jq_prebooking_id", String(prebookingId));
        }

        setStatus("Redirigiendo al pago...");
        window.location.href = String(paymentUrl);
      } catch (error) {
        setStatus(error instanceof Error ? error.message : "No se pudo completar la pre-reserva.", "error");
        setBusy(false);
      }
    });

    if (dateInput) {
      dateInput.min = new Date().toISOString().split("T")[0];
    }

    confirmPayment();
  }
</script>
