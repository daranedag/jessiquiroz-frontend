---
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL || "";
const apiV1Path = import.meta.env.PUBLIC_API_V1_PATH || "/api/v1";
const appTimezone = import.meta.env.PUBLIC_APP_TIMEZONE || "America/Santiago";
---

<section
  id="agendamiento"
  class="bg-white py-16"
  data-booking-flow
  data-api-base-url={apiBaseUrl}
  data-api-v1-path={apiV1Path}
  data-app-timezone={appTimezone}
>
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-secondary">Agenda</p>
        <h2 class="mt-2 font-display text-3xl text-text-main sm:text-4xl">Reserva tu sesión</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Selecciona una hora disponible, comparte tus datos y completa el pago para confirmar la reserva.
        </p>

        <div class="mt-8 grid gap-4 text-sm text-slate-700">
          <div class="flex gap-3">
            <span class="material-icons text-primary">event_available</span>
            <span>La hora queda retenida al crear la pre-reserva.</span>
          </div>
          <div class="flex gap-3">
            <span class="material-icons text-primary">image</span>
            <span>Puedes adjuntar imágenes antes de pagar.</span>
          </div>
          <div class="flex gap-3">
            <span class="material-icons text-primary">verified</span>
            <span>La reserva se confirma cuando el backend valida el pago.</span>
          </div>
        </div>
      </div>

      <form class="space-y-8 rounded-3xl border border-primary/10 bg-background/50 p-6 shadow-sm sm:p-8" data-booking-form>
        <div class="flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
          <span class="rounded-full bg-primary px-4 py-2 text-white" data-step-indicator="1">Datos</span>
          <span class="rounded-full bg-white px-4 py-2 text-primary" data-step-indicator="2">Horario</span>
          <span class="rounded-full bg-white px-4 py-2 text-primary" data-step-indicator="3">Pago</span>
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Nombre</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="name"
              autocomplete="name"
              required
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Email</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="email"
              type="email"
              autocomplete="email"
              required
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Teléfono</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="phone"
              type="tel"
              autocomplete="tel"
            />
          </label>
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Servicio</span>
            <select
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="service"
              required
              data-service-select
            >
              <option value="">Cargando servicios...</option>
            </select>
          </label>
        </div>

        <div class="grid gap-5 sm:grid-cols-[0.75fr_1.25fr]">
          <label class="space-y-2 text-sm font-medium text-text-main">
            <span>Fecha</span>
            <input
              class="w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
              name="date"
              type="date"
              required
              data-date-input
            />
          </label>

          <div class="space-y-2">
            <span class="block text-sm font-medium text-text-main">Horas disponibles</span>
            <div class="grid min-h-14 grid-cols-2 gap-3 sm:grid-cols-3" data-slot-list>
              <p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">Elige servicio y fecha.</p>
            </div>
          </div>
        </div>

        <input type="hidden" name="startsAt" data-starts-at-input />
        <input type="hidden" name="endsAt" data-ends-at-input />

        <label class="space-y-2 text-sm font-medium text-text-main">
          <span>Mensaje</span>
          <textarea
            class="min-h-28 w-full rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10"
            name="notes"
            maxlength="700"
          ></textarea>
        </label>

        <label class="block space-y-3 text-sm font-medium text-text-main">
          <span>Imágenes (opcional)</span>
          <input
            class="block w-full rounded-2xl border border-dashed border-primary/30 bg-white px-4 py-6 text-sm text-slate-600 file:mr-4 file:rounded-full file:border-0 file:bg-primary file:px-4 file:py-2 file:text-sm file:font-semibold file:text-white"
            name="files"
            type="file"
            accept="image/*"
            multiple
            data-file-input
          />
          <span class="block text-xs font-normal text-slate-500" data-file-summary>Máximo 6 imágenes, 8 MB por archivo.</span>
        </label>

        <label class="flex items-start gap-3 text-sm text-slate-600">
          <input class="mt-1 h-4 w-4 rounded border-primary/30 text-primary" type="checkbox" name="acceptTerms" required />
          <span>Acepto compartir estos datos para gestionar mi reserva y pago.</span>
        </label>

        <div class="rounded-2xl border border-primary/10 bg-white px-4 py-3 text-sm text-slate-600" role="status" data-booking-status>
          Completa los datos para continuar.
        </div>

        <button
          class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-cta px-8 py-4 text-xs font-bold uppercase tracking-[0.2em] text-text-main shadow-lg ring-2 ring-cta/70 transition hover:-translate-y-0.5 hover:shadow-2xl disabled:cursor-not-allowed disabled:opacity-60 disabled:hover:translate-y-0"
          type="submit"
          data-submit-button
        >
          <span class="material-icons text-base">payments</span>
          Ir al pago
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  type Service = {
    id: string;
    name: string;
    description: string | null;
    duration_minutes: number;
    price_amount: number;
    currency: string;
    active: boolean;
  };

  type Slot = {
    startsAt: string;
    endsAt: string;
    timezone: string;
  };

  type PreReservationResponse = {
    data?: {
      preReservation?: {
        id: string;
      };
      customerToken?: string;
    };
  };

  type PaymentResponse = {
    data?: {
      paymentId?: string;
      preferenceId?: string;
      initPoint?: string | null;
      sandboxInitPoint?: string | null;
    };
  };

  type PaymentStatusResponse = {
    data?: {
      preReservationStatus?: string;
      paymentStatus?: string | null;
      bookingId?: string | null;
    };
  };

  const flow = document.querySelector<HTMLElement>("[data-booking-flow]");

  if (flow) {
    const form = flow.querySelector<HTMLFormElement>("[data-booking-form]");
    const serviceSelect = flow.querySelector<HTMLSelectElement>("[data-service-select]");
    const slotList = flow.querySelector<HTMLElement>("[data-slot-list]");
    const startsAtInput = flow.querySelector<HTMLInputElement>("[data-starts-at-input]");
    const endsAtInput = flow.querySelector<HTMLInputElement>("[data-ends-at-input]");
    const dateInput = flow.querySelector<HTMLInputElement>("[data-date-input]");
    const fileInput = flow.querySelector<HTMLInputElement>("[data-file-input]");
    const fileSummary = flow.querySelector<HTMLElement>("[data-file-summary]");
    const statusBox = flow.querySelector<HTMLElement>("[data-booking-status]");
    const submitButton = flow.querySelector<HTMLButtonElement>("[data-submit-button]");
    const indicators = Array.from(flow.querySelectorAll<HTMLElement>("[data-step-indicator]"));

    const apiBaseUrl = flow.dataset.apiBaseUrl?.replace(/\/$/, "") || "";
    const apiV1Path = flow.dataset.apiV1Path?.replace(/^\/?/, "/").replace(/\/$/, "") || "/api/v1";
    const timezone = flow.dataset.appTimezone || "America/Santiago";
    const maxFiles = 6;
    const maxFileSize = 8 * 1024 * 1024;
    const reservationIdKey = "jq_pre_reservation_id";
    const reservationTokenKey = "jq_customer_token";

    const endpoint = (path: string) => `${apiBaseUrl}${apiV1Path}${path.startsWith("/") ? path : `/${path}`}`;

    const setStatus = (message: string, tone: "neutral" | "error" | "success" = "neutral") => {
      if (!statusBox) return;
      const toneClasses = {
        neutral: "border-primary/10 bg-white text-slate-600",
        error: "border-red-200 bg-red-50 text-red-700",
        success: "border-green-200 bg-green-50 text-green-700",
      };
      statusBox.className = `rounded-2xl border px-4 py-3 text-sm ${toneClasses[tone]}`;
      statusBox.textContent = message;
    };

    const setStep = (step: string) => {
      indicators.forEach((indicator) => {
        const isActive = indicator.dataset.stepIndicator === step;
        indicator.classList.toggle("bg-primary", isActive);
        indicator.classList.toggle("text-white", isActive);
        indicator.classList.toggle("bg-white", !isActive);
        indicator.classList.toggle("text-primary", !isActive);
      });
    };

    const setBusy = (busy: boolean) => {
      if (!submitButton) return;
      submitButton.disabled = busy;
      submitButton.querySelector("span")?.classList.toggle("animate-pulse", busy);
    };

    const getApiError = async (response: Response, fallback: string) => {
      try {
        const payload = await response.json();
        return payload?.error?.message ?? payload?.error?.code ?? fallback;
      } catch {
        return fallback;
      }
    };

    const formatMoney = (amount: number, currency: string) =>
      new Intl.NumberFormat("es-CL", {
        style: "currency",
        currency,
        maximumFractionDigits: 0,
      }).format(amount);

    const formatSlotLabel = (slot: Slot) => {
      const start = new Date(slot.startsAt);
      const end = new Date(slot.endsAt);
      return `${start.toLocaleTimeString("es-CL", {
        hour: "2-digit",
        minute: "2-digit",
        timeZone: slot.timezone || timezone,
      })} - ${end.toLocaleTimeString("es-CL", {
        hour: "2-digit",
        minute: "2-digit",
        timeZone: slot.timezone || timezone,
      })}`;
    };

    const getDayRange = (date: string) => {
      const start = new Date(`${date}T00:00:00`);
      const end = new Date(start);
      end.setDate(start.getDate() + 1);
      return {
        from: start.toISOString(),
        to: end.toISOString(),
      };
    };

    const clearSlots = (message = "Elige servicio y fecha.") => {
      if (!slotList || !startsAtInput || !endsAtInput) return;
      startsAtInput.value = "";
      endsAtInput.value = "";
      slotList.innerHTML = `<p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">${message}</p>`;
    };

    const loadServices = async () => {
      if (!serviceSelect) return;
      if (!apiBaseUrl) {
        serviceSelect.innerHTML = '<option value="">Configura PUBLIC_API_BASE_URL</option>';
        setStatus("Falta configurar PUBLIC_API_BASE_URL.", "error");
        return;
      }

      try {
        const response = await fetch(endpoint("/services"), { headers: { Accept: "application/json" } });
        if (!response.ok) throw new Error(await getApiError(response, "No se pudieron cargar los servicios."));
        const payload = await response.json();
        const services = (payload.data ?? []) as Service[];
        const activeServices = services.filter((service) => service.active);

        serviceSelect.innerHTML = '<option value="">Selecciona</option>';
        activeServices.forEach((service) => {
          const option = document.createElement("option");
          option.value = service.id;
          option.textContent = `${service.name} · ${service.duration_minutes} min · ${formatMoney(
            service.price_amount,
            service.currency
          )}`;
          serviceSelect.append(option);
        });

        if (!activeServices.length) {
          serviceSelect.innerHTML = '<option value="">No hay servicios disponibles</option>';
        }
      } catch (error) {
        serviceSelect.innerHTML = '<option value="">No se pudieron cargar servicios</option>';
        setStatus(error instanceof Error ? error.message : "No se pudieron cargar los servicios.", "error");
      }
    };

    const renderSlots = (slots: Slot[]) => {
      if (!slotList || !startsAtInput || !endsAtInput) return;
      startsAtInput.value = "";
      endsAtInput.value = "";
      slotList.innerHTML = "";

      if (!slots.length) {
        clearSlots("No hay horas disponibles para esa fecha.");
        return;
      }

      slots.forEach((slot) => {
        const button = document.createElement("button");
        button.type = "button";
        button.className =
          "rounded-2xl border border-primary/20 bg-white px-4 py-3 text-sm font-semibold text-primary transition hover:border-primary hover:bg-primary hover:text-white";
        button.textContent = formatSlotLabel(slot);
        button.addEventListener("click", () => {
          startsAtInput.value = slot.startsAt;
          endsAtInput.value = slot.endsAt;
          slotList.querySelectorAll("button").forEach((item) => {
            item.classList.remove("border-primary", "bg-primary", "text-white");
            item.classList.add("border-primary/20", "bg-white", "text-primary");
          });
          button.classList.add("border-primary", "bg-primary", "text-white");
          button.classList.remove("border-primary/20", "bg-white", "text-primary");
          setStep("3");
          setStatus("Hora seleccionada. Puedes continuar al pago.");
        });
        slotList.append(button);
      });
    };

    const loadAvailability = async () => {
      if (!form || !slotList) return;
      const formData = new FormData(form);
      const serviceId = String(formData.get("service") ?? "");
      const date = String(formData.get("date") ?? "");

      if (!serviceId || !date) {
        clearSlots();
        setStatus("Elige servicio y fecha para consultar disponibilidad.");
        return;
      }

      if (!apiBaseUrl) {
        setStatus("Falta configurar PUBLIC_API_BASE_URL.", "error");
        return;
      }

      setStep("2");
      slotList.innerHTML = '<p class="col-span-full rounded-2xl bg-white px-4 py-3 text-sm text-slate-500">Consultando disponibilidad...</p>';

      try {
        const { from, to } = getDayRange(date);
        const url = new URL(endpoint("/availability"));
        url.searchParams.set("serviceId", serviceId);
        url.searchParams.set("from", from);
        url.searchParams.set("to", to);
        url.searchParams.set("timezone", timezone);
        const response = await fetch(url, { headers: { Accept: "application/json" } });
        if (!response.ok) throw new Error(await getApiError(response, "No se pudo consultar disponibilidad."));
        const payload = await response.json();
        renderSlots((payload.data ?? []) as Slot[]);
      } catch (error) {
        clearSlots("No se pudo consultar disponibilidad.");
        setStatus(error instanceof Error ? error.message : "No se pudo consultar disponibilidad.", "error");
      }
    };

    const validateFiles = () => {
      const files = Array.from(fileInput?.files ?? []);
      if (files.length > maxFiles) {
        throw new Error(`Puedes subir hasta ${maxFiles} imágenes.`);
      }
      const invalidFile = files.find((file) => !file.type.startsWith("image/") || file.size > maxFileSize);
      if (invalidFile) {
        throw new Error(`Revisa ${invalidFile.name}: solo imágenes de hasta 8 MB.`);
      }
      if (fileSummary) {
        fileSummary.textContent = files.length ? `${files.length} imagen(es) seleccionada(s).` : "Máximo 6 imágenes, 8 MB por archivo.";
      }
      return files;
    };

    const createPreReservation = async (payload: Record<string, unknown>) => {
      const response = await fetch(endpoint("/pre-reservations"), {
        method: "POST",
        headers: {
          Accept: "application/json",
          "Content-Type": "application/json",
        },
        body: JSON.stringify(payload),
      });
      if (!response.ok) throw new Error(await getApiError(response, "No se pudo iniciar la pre-reserva."));
      return response.json() as Promise<PreReservationResponse>;
    };

    const uploadImages = async (preReservationId: string, customerToken: string, files: File[]) => {
      if (!files.length) return [];
      const body = new FormData();
      files.forEach((file) => body.append("images", file));

      const response = await fetch(endpoint(`/pre-reservations/${preReservationId}/images`), {
        method: "POST",
        headers: {
          "X-Reservation-Token": customerToken,
        },
        body,
      });
      if (!response.ok) throw new Error(await getApiError(response, "No se pudieron subir las imágenes."));
      const payload = await response.json();
      return payload.data ?? [];
    };

    const createPayment = async (preReservationId: string, customerToken: string) => {
      const response = await fetch(endpoint(`/pre-reservations/${preReservationId}/payment`), {
        method: "POST",
        headers: {
          Accept: "application/json",
          "X-Reservation-Token": customerToken,
        },
      });
      if (!response.ok) throw new Error(await getApiError(response, "No se pudo crear la preferencia de pago."));
      return response.json() as Promise<PaymentResponse>;
    };

    const checkPaymentStatus = async () => {
      if (!apiBaseUrl) return;
      const params = new URLSearchParams(window.location.search);
      const status = params.get("payment_status") ?? params.get("status") ?? params.get("collection_status");
      const shouldCheck = status === "success" || status === "approved" || status === "pending";
      if (!shouldCheck) return;

      const preReservationId =
        params.get("preReservationId") ?? window.sessionStorage.getItem(reservationIdKey);
      const customerToken = window.sessionStorage.getItem(reservationTokenKey);

      if (!preReservationId || !customerToken) {
        setStatus("Pago recibido, pero falta información local para consultar el estado.", "error");
        return;
      }

      setStep("3");
      setStatus("Consultando estado del pago...");

      try {
        const response = await fetch(endpoint(`/pre-reservations/${preReservationId}/payment-status`), {
          headers: {
            Accept: "application/json",
            "X-Reservation-Token": customerToken,
          },
        });
        if (!response.ok) throw new Error(await getApiError(response, "No se pudo consultar el estado del pago."));
        const payload = (await response.json()) as PaymentStatusResponse;
        const data = payload.data;

        if (data?.bookingId) {
          setStatus("Pago confirmado. Tu hora quedó agendada.", "success");
          return;
        }

        if (data?.paymentStatus === "pending" || data?.preReservationStatus === "awaiting_payment") {
          setStatus("El pago está pendiente. Te avisaremos cuando el backend confirme la reserva.");
          return;
        }

        setStatus("Aún no hay confirmación de reserva. Revisa nuevamente en unos minutos.");
      } catch (error) {
        setStatus(error instanceof Error ? error.message : "No se pudo consultar el estado del pago.", "error");
      }
    };

    form?.addEventListener("change", (event) => {
      const target = event.target as HTMLInputElement | HTMLSelectElement;
      if (target.name === "service" || target.name === "date") {
        loadAvailability();
      }
      if (target === fileInput) {
        try {
          validateFiles();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Archivo no válido.", "error");
          if (fileInput) fileInput.value = "";
        }
      }
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      try {
        if (!apiBaseUrl) throw new Error("Falta configurar PUBLIC_API_BASE_URL.");
        if (!form.reportValidity()) return;

        const formData = new FormData(form);
        const serviceId = String(formData.get("service") ?? "");
        const startsAt = String(formData.get("startsAt") ?? "");
        const endsAt = String(formData.get("endsAt") ?? "");
        if (!startsAt || !endsAt) throw new Error("Selecciona una hora disponible.");

        setBusy(true);
        setStatus("Creando pre-reserva...");

        const files = validateFiles();
        const preReservationPayload = {
          serviceId,
          startsAt,
          timezone,
          client: {
            fullName: formData.get("name"),
            email: formData.get("email"),
            phone: formData.get("phone") || undefined,
            notes: formData.get("notes") || undefined,
            formData: {
              endsAt,
              source: "github-pages-frontend",
            },
          },
        };

        const preReservationResult = await createPreReservation(preReservationPayload);
        const preReservation = preReservationResult.data?.preReservation;
        const customerToken = preReservationResult.data?.customerToken;
        if (!preReservation?.id || !customerToken) {
          throw new Error("El backend no devolvió pre-reserva o token de cliente.");
        }

        window.sessionStorage.setItem(reservationIdKey, preReservation.id);
        window.sessionStorage.setItem(reservationTokenKey, customerToken);

        setStatus("Subiendo imágenes...");
        await uploadImages(preReservation.id, customerToken, files);

        setStatus("Creando preferencia de pago...");
        const paymentResult = await createPayment(preReservation.id, customerToken);
        const checkoutUrl = paymentResult.data?.initPoint ?? paymentResult.data?.sandboxInitPoint;
        if (!checkoutUrl) throw new Error("El backend no devolvió una URL de pago.");

        setStatus("Redirigiendo al pago...");
        window.location.href = checkoutUrl;
      } catch (error) {
        setStatus(error instanceof Error ? error.message : "No se pudo completar la pre-reserva.", "error");
        setBusy(false);
      }
    });

    if (dateInput) {
      dateInput.min = new Date().toISOString().split("T")[0];
    }

    loadServices();
    checkPaymentStatus();
  }
</script>
